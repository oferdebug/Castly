# Database
POSTGRES_USER=podcast
POSTGRES_PASSWORD=podcast_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Auth DB
AUTH_DB_NAME=auth_db
AUTH_DB_URL=postgresql://podcast:podcast_dev@localhost:5432/auth_db

# Podcast DB
PODCAST_DB_NAME=podcast_db
PODCAST_DB_URL=postgresql://podcast:podcast_dev@localhost:5432/podcast_db

# AI DB
AI_DB_NAME=ai_db
AI_DB_URL=postgresql://podcast:podcast_dev@localhost:5432/ai_db

# Search DB
SEARCH_DB_NAME=search_db
SEARCH_DB_URL=postgresql://podcast:podcast_dev@localhost:5432/search_db

# Analytics DB
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_URL=postgresql://podcast:podcast_dev@localhost:5432/analytics_db

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=podcast-audio
S3_REGION=us-east-1

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Internal service key
INTERNAL_API_KEY=dev-internal-key

# AI APIs
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Service URLs (for Docker networking)
AUTH_SERVICE_URL=http://localhost:4001
PODCAST_SERVICE_URL=http://localhost:4002
AI_SERVICE_URL=http://localhost:4003
SEARCH_SERVICE_URL=http://localhost:4004
ANALYTICS_SERVICE_URL=http://localhost:4005
